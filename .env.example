# ─── Copy this file to .env and fill in your values ────────────────────────
# Never commit .env to Git!

# Database
DB_URL=jdbc:postgresql://localhost:5432/cafe_erp
DB_USERNAME=cafe_user
DB_PASSWORD=your_secure_db_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=your_secure_random_256bit_key_here

# CORS — comma-separated allowed origins (no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Server
SERVER_PORT=8080
